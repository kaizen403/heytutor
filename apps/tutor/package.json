{
  "name": "@heytutor/tutor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:reset": "rm -rf .next && tsx scripts/dev.ts",
    "dev:next": "next dev",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts",
    "start:next": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf .next",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e .env.local -- prisma migrate dev",
    "postinstall": "prisma generate",
    "r2:setup": "tsx scripts/r2-setup.ts",
    "verify": "tsx scripts/verify-board-title.ts && tsx scripts/verify-replay.ts"
  },
  "dependencies": {
    "@heytutor/design-tokens": "workspace:*",
    "@heytutor/drawing": "workspace:*",
    "@heytutor/tutor-core": "workspace:*",
    "@heytutor/whiteboard": "workspace:*",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "jspdf": "^4.2.1",
    "konva": "^10.3.0",
    "langfuse": "^3.38.20",
    "lucide-react": "^1.21.0",
    "next": "15.3.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-konva": "^19.2.5",
    "roughjs": "^4.6.6",
    "tailwind-merge": "^3.6.0",
    "tegaki": "^0.18.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@heytutor/eslint-config": "workspace:*",
    "@heytutor/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
