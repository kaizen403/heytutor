{
  "name": "@heytutor/tutor-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external @heytutor/drawing",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@heytutor/drawing": "workspace:*"
  },
  "devDependencies": {
    "@heytutor/typescript-config": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
